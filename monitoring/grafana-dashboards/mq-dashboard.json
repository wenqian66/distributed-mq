{
  "uid": "mq-overview",
  "title": "MQ Service Overview",
  "tags": ["mq", "kafka"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Message Throughput (sent/s by priority)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(messages_sent_total[1m])) by (priority)",
          "legendFormat": "{{priority}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Consumer Latency (fetch avg ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "kafka_consumer_fetch_latency_avg{job=\"mq-service\"}",
          "legendFormat": "fetch latency avg",
          "refId": "A"
        },
        {
          "expr": "rate(message_lookup_latency_seconds_sum[1m]) / rate(message_lookup_latency_seconds_count[1m]) * 1000",
          "legendFormat": "message lookup latency avg",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Consumer Group Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 30, "lineWidth": 1 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(kafka_consumergroup_lag{consumergroup=\"order-processors\"}) by (topic)",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Cache Hit Rate (%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(cache_hit_total{service=\"message\"}[5m])) / (sum(rate(cache_hit_total{service=\"message\"}[5m])) + sum(rate(cache_miss_total{service=\"message\"}[5m])))",
          "legendFormat": "hit rate",
          "refId": "A"
        }
      ]
    }
  ]
}
